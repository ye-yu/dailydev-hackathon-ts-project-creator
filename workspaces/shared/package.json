{
  "name": "@ye-yu/shared",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ./bin/build-openapi-client.mts && tsgo -p ./tsconfig.build.json"
  },
  "exports": {
    "./entities": {
      "types": "./dist/entities.d.ts",
      "default": "./dist/entities.js"
    },
    "./blog-api": {
      "types": "./dist/blog-api.d.ts",
      "default": "./dist/blog-api.js"
    },
    "./daily-dev": {
      "types": "./dist/daily-dev-openapi/api.types.d.ts",
      "default": "./dist/daily-dev-openapi/api.types.js"
    },
    "./daily-dev-schema": {
      "types": "./dist/daily-dev-openapi/schemas.d.ts",
      "default": "./dist/daily-dev-openapi/schemas.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "default": "./dist/utils.js"
    },
    "./logger": {
      "types": "./dist/logger/logger.d.ts",
      "default": "./dist/logger/logger.js"
    }
  },
  "dependencies": {
    "@ye-yu/database": "workspace:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:"
  }
}
