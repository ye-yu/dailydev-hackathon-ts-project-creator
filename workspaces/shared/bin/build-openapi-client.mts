import path from "node:path";
import fs from "node:fs";
import openapiJson from "./daily-dev-openapi/openapi.json" with { type: "json" };
import { fileURLToPath } from "node:url";
const scriptDir = fileURLToPath(new URL(".", import.meta.url));
const dir = path.join(scriptDir, "..", "src", "daily-dev-openapi");
fs.mkdirSync(dir, { recursive: true });

function buildType(schema: object, parent?: object, indent = 0, importSpecifier?: string): string {
  if ("$ref" in schema) {
    const ref = `${schema.$ref}`;
    if (!ref.startsWith("#/")) {
      throw new Error(`Expected $ref to start with "#/", but got ${ref}`, {
        cause: { schema, parent },
      });
    }

    const refPath = ref.slice(2).split("/");
    let refSchema: object = openapiJson;
    for (const segment of refPath) {
      if (!(segment in refSchema)) {
        throw new Error(`Invalid $ref path: ${ref}, segment "${segment}" not found in schema`, {
          cause: { schema, parent },
        });
      }
      if (typeof refSchema !== "object" || refSchema === null) {
        throw new Error(
          `Invalid $ref path: ${ref}, segment "${segment}" does not point to an object`,
          { cause: { schema, parent } },
        );
      }
      const segmentContent = Reflect.get(refSchema, segment);
      refSchema = segmentContent;
    }

    if (!("title" in refSchema)) {
      throw new Error(
        `Expected referenced schema to have a "title" property, but got ${JSON.stringify(refSchema)}`,
        { cause: { schema, parent } },
      );
    }

    const nullable = "nullable" in schema && schema.nullable ? " | null" : "";
    const prefix = importSpecifier ? `${importSpecifier}.` : "";
    return `${prefix}${refSchema.title}${nullable}`;
  }
  if (!("type" in schema)) {
    throw new Error(
      `Expected schema to have a "type" property, but got ${JSON.stringify(schema)}`,
      { cause: { schema, parent } },
    );
  }

  const type = `${schema.type}`;
  switch (type) {
    case "object": {
      if (!("properties" in schema)) {
        throw new Error(
          `Expected object schema to have a "properties" property, but got ${JSON.stringify(schema)}`,
          { cause: { schema, parent } },
        );
      }
      const properties = schema.properties as object;
      const result: Record<string, string> = {};
      for (const key of Object.keys(properties) as (keyof typeof properties)[]) {
        try {
          result[key] = buildType(properties[key], parent ?? schema, indent + 2, importSpecifier);
        } catch (error) {
          throw new Error(`Error processing property "${key}": ${(error as Error).message}`, {
            cause: { schema: properties[key], parent: schema, error },
          });
        }
      }
      if (!("title" in schema)) {
        return `{\n${Object.entries(result)
          .map(([key, value]) => `${" ".repeat(indent + 2)}${key}: ${value};`)
          .join("\n")}\n${" ".repeat(indent)}}`;
      }
      const title = schema.title as string;

      return `interface ${title} {\n${Object.entries(result)
        .map(([key, value]) => `${" ".repeat(indent + 2)}${key}: ${value};`)
        .join("\n")}\n${" ".repeat(indent)}}`;
    }
    case "array": {
      if (!("items" in schema)) {
        throw new Error(
          `Expected array schema to have an "items" property, but got ${JSON.stringify(schema)}`,
          { cause: { schema, parent } },
        );
      }
      const items = schema.items as object;
      try {
        return `Array<${buildType(items, parent ?? schema, indent + 2, importSpecifier)}>`;
      } catch (error) {
        throw new Error(`Error processing items of array schema: ${(error as Error).message}`, {
          cause: { schema: items, parent: schema, error },
        });
      }
    }
    case "string": {
      const nullable = "nullable" in schema && schema.nullable ? " | null" : "";
      return `string${nullable}`;
    }
    case "number":
    case "integer": {
      const nullable = "nullable" in schema && schema.nullable ? " | null" : "";
      return `number${nullable}`;
    }
    case "boolean": {
      const nullable = "nullable" in schema && schema.nullable ? " | null" : "";
      return `boolean${nullable}`;
    }
    default: {
      throw new Error(`Unsupported schema type: ${type}`, { cause: { schema, parent } });
    }
  }
}

const schemas = openapiJson.components.schemas;
const schemaExports = Object.keys(schemas)
  .map((key) => {
    const schemaKey = key as keyof typeof schemas;
    const schema = schemas[schemaKey];
    return `export ${buildType(schema)}`;
  })
  .join("\n\n");

const fileContent = `/** This file is auto-generated by ${path.basename(fileURLToPath(import.meta.url))}. Do not edit directly. */
${schemaExports}
`;
const outputPath = path.join(dir, "schemas.ts");
fs.writeFileSync(outputPath, fileContent);
console.info(`Generated OpenAPI client schemas at ${outputPath}`);

const paths = openapiJson.paths;

function descriptionToIdentifier(description: string, method = ""): string {
  const prefix = description
    .toLocaleLowerCase("en-us")
    .startsWith(method.toLocaleLowerCase("en-us"))
    ? ""
    : method.charAt(0).toUpperCase() + method.slice(1);
  return (
    prefix +
    description
      .split(/[^\w]+/g)
      .slice(0, 10)
      .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
      .join("")
  );
}

const apiTypesOutputPath = path.join(dir, `api.types.ts`);
const apiTypesWriteStream = fs.createWriteStream(apiTypesOutputPath);
apiTypesWriteStream.write(
  `/** This file is auto-generated by ${path.basename(fileURLToPath(import.meta.url))}. Do not edit directly. */\n`,
);
apiTypesWriteStream.write(`import type * as openapi from "./schemas.ts";\n\n`);
const createRequestInitOverrides = [] as Array<{
  id: string;
  method: string;
  path: string;
  queryParamsDef: string | null;
  pathParamsDef: string | null;
  requestBodyDef: string | null;
}>;
for (const urlPath of Object.keys(paths) as (keyof typeof paths)[]) {
  const pathDef = paths[urlPath];
  for (const method of Object.keys(pathDef) as (keyof typeof pathDef)[]) {
    const exportStatements: string[] = [];
    const methodStr = `${method}`;
    const methodDef = pathDef[method] as {
      description: string;
      requestBody?: object;
      responses: Record<number, object>;
      parameters?: object[];
    };

    let queryParamsDef: string | null = null;
    let pathParamsDef: string | null = null;
    let requestBodyDef: string | null = null;
    const prefix = descriptionToIdentifier(methodDef.description, methodStr);

    if (methodDef.parameters) {
      const queryParameters = methodDef.parameters.filter(
        (param) => "in" in param && param.in === "query",
      );
      const pathParameters = methodDef.parameters.filter(
        (param) => "in" in param && param.in === "path",
      );
      if (queryParameters.length) {
        const def = `${prefix}QueryParams`;
        const params = queryParameters.map((param: object) => {
          const paramObj = param as { name: string; schema: object };
          const name = paramObj.name;
          const type = buildType(paramObj.schema, undefined, 0, "openapi");
          return `  ${name}: ${type};`;
        });
        const exportStatement = `export type ${def} = {\n${params.join("\n")}\n}`;
        exportStatements.push(exportStatement);
        queryParamsDef = def;
      }
      if (pathParameters.length) {
        const def = `${prefix}PathParams`;
        const params = pathParameters.map((param: object) => {
          const paramObj = param as { name: string; schema: object };
          const name = paramObj.name;
          const type = buildType(paramObj.schema, undefined, 0, "openapi");
          return `  ${name}: ${type};`;
        });
        const exportStatement = `export type ${def} = {\n${params.join("\n")}\n}`;
        exportStatements.push(exportStatement);
        pathParamsDef = def;
      }
    }

    if (methodDef.requestBody) {
      const def = `${prefix}RequestBody`;
      if (!("content" in methodDef.requestBody)) {
        continue;
      }
      const content = methodDef.requestBody.content as Record<string, object>;
      if (!("application/json" in content)) {
        continue;
      }
      const jsonContent = content["application/json"] as { schema: object };
      const type = buildType(jsonContent.schema, undefined, 0, "openapi");
      const exportStatement = `export type ${def} = ${type}`;
      exportStatements.push(exportStatement);
      requestBodyDef = def;
    }

    const responseTypes = [] as [number, string][];
    for (const _responseCode of Object.keys(methodDef.responses)) {
      const responseCode = Number(_responseCode);
      const responseDef = methodDef.responses[responseCode] as {
        description: string;
        content?: object;
      };
      if (!responseDef.content) {
        continue;
      }
      const def = `${prefix}Response${responseCode}`;
      const content = responseDef.content as Record<string, object>;
      if (!("application/json" in content)) {
        continue;
      }
      const jsonContent = content["application/json"] as { schema: object };
      const type = buildType(jsonContent.schema, undefined, 0, "openapi");
      const exportStatement = `export type ${def} = ${type}`;
      exportStatements.push(exportStatement);
      responseTypes.push([responseCode, def]);
    }

    const responseDef = `${prefix}Response`;
    const exportResponseStatement = `export type ${responseDef} = [${responseTypes.map(([code, def]) => `[${code}, ${def}]`).join(", ")}]`;
    exportStatements.push(exportResponseStatement);

    apiTypesWriteStream.write(`\n${exportStatements.join("\n\n")}\n`);

    const exportRequestResponseStatement = [
      `export interface ${prefix}API {`,
      `  id: "${prefix}";`,
      `  method: "${methodStr}";`,
      `  query: ${queryParamsDef ?? "null"};`,
      `  pathParams: ${pathParamsDef ?? "null"};`,
      `  requestBody: ${requestBodyDef ?? "null"};`,
      `  response: ${responseDef};`,
      `}`,
    ].join("\n");
    apiTypesWriteStream.write(`\n${exportRequestResponseStatement}\n`);

    createRequestInitOverrides.push({
      id: prefix,
      method: methodStr,
      path: urlPath,
      queryParamsDef,
      pathParamsDef,
      requestBodyDef,
    });
  }
}

apiTypesWriteStream.write(`\nconst baseURL = "https://dev.to/api";`);
apiTypesWriteStream.write(`\nconst idToUrl: Record<string, string> = {\n`);
for (const override of createRequestInitOverrides) {
  apiTypesWriteStream.write(`  "${override.id}": "${override.path}",\n`);
}
apiTypesWriteStream.write(`}\n`);

for (const override of createRequestInitOverrides) {
  const { id, method, queryParamsDef, pathParamsDef, requestBodyDef } = override;
  if (queryParamsDef || pathParamsDef || requestBodyDef) {
    apiTypesWriteStream.write(
      `export function createDailyDevRequestInit(id: "${id}", method: "${method}", data: {`,
    );
    if (queryParamsDef) {
      apiTypesWriteStream.write(`\n  searchParams: ${queryParamsDef};`);
    }
    if (pathParamsDef) {
      apiTypesWriteStream.write(`\n  pathParams: ${pathParamsDef};`);
    }
    if (requestBodyDef) {
      apiTypesWriteStream.write(`\n  body: ${requestBodyDef};`);
    }
    apiTypesWriteStream.write(`\n}): RequestInit & { id: "${id}" };\n`);
  }
}

const createRequestInitTemplatePath = path.join(
  scriptDir,
  "daily-dev-openapi",
  "create-request-init.ts.template",
);
const createRequestInitTemplate = fs.readFileSync(createRequestInitTemplatePath, "utf-8");
apiTypesWriteStream.write(`\n${createRequestInitTemplate}\n`);

apiTypesWriteStream.write(`\ndeclare global {\n`);
apiTypesWriteStream.write(`
  export type FetchMoreResult<Responses extends [number, unknown][]> = {
    [K in Responses[number][0]]: {
      status: K;
      json(): Promise<Extract<Responses[number], [K, unknown]>[1]>;
    };
  }[Responses[number][0]];

`);
for (const overrides of createRequestInitOverrides) {
  const { id } = overrides;
  apiTypesWriteStream.write(
    `  export function fetch(url: RequestInit & { id: "${id}" }): PromiseLike<Omit<Response, "status" | "json"> & FetchMoreResult<${id}Response>>;\n`,
  );
}
apiTypesWriteStream.write(`}\n`);

apiTypesWriteStream.end();
console.info(`Generated OpenAPI client types at ${apiTypesOutputPath}`);
