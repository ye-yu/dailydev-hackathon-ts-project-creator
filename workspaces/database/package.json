{
  "name": "@ye-yu/database",
  "version": "1.0.0",
  "private": true,
  "files": [
    "build"
  ],
  "type": "commonjs",
  "types": "./dist/index.d.ts",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "catalog:",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@typescript/native-preview": "catalog:",
    "better-sqlite3": "^12.10.0",
    "reflect-metadata": "catalog:",
    "rimraf": "^6.1.3",
    "typeorm": "catalog:"
  },
  "scripts": {
    "clean": "pnpm clean:dist && pnpm clean:build",
    "clean:dist": "rimraf dist tsconfig.entities.tsbuildinfo",
    "clean:build": "rimraf build tsconfig.build.tsbuildinfo",
    "generate:entities": "node ./bin/export-entities.cts",
    "prepack": "pnpm clean:dist && pnpm generate:entities && tsgo -p ./tsconfig.entities.json",
    "build": "tsgo -p ./tsconfig.build.json",
    "start": "ts-node src/index.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "pnpm build && node ./bin/create-migration.cts",
    "migration:up": "pnpm build && pnpm migration:clean && node ./bin/migration-up.cts",
    "migration:down": "pnpm build && pnpm migration:clean && node ./bin/migration-down.cts",
    "migration:clean": "node ./bin/clean-migration.cts"
  }
}
