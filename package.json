{
  "name": "ts-project-creator",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "build:backend": "pnpm --filter @ye-yu/backend build",
    "build:database": "pnpm --filter @ye-yu/database build",
    "build:shared": "pnpm --filter @ye-yu/shared build",
    "build:frontend": "pnpm --filter @ye-yu/frontend build",
    "build": "pnpm build:database && pnpm build:shared && run-p build:backend build:frontend",
    "start:backend": "pnpm --filter @ye-yu/backend start",
    "start:frontend": "pnpm --filter @ye-yu/frontend dev",
    "start": "run-p start:*",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "oxfmt src/",
    "install:all": "pnpm install -r",
    "frontend:dev": "pnpm --filter @ye-yu/frontend dev"
  },
  "devDependencies": {
    "npm-run-all2": "catalog:",
    "@vitest/eslint-plugin": "catalog:",
    "@vue/eslint-config-typescript": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-oxlint": "catalog:",
    "eslint-plugin-playwright": "catalog:",
    "eslint-plugin-vue": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:"
  }
}
